# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

cat > .gitignore <<'EOF'
# OS
.DS_Store

# Node / Frontend
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local

# Laravel / Backend
backend/vendor/
backend/.env
backend/storage/*.key
backend/storage/logs/*.log
backend/bootstrap/cache/*.php

# Android
android-companion/.gradle/
android-companion/build/
android-companion/app/build/
android-companion/local.properties
android-companion/gradle-*.zip

# IDE
.vscode/
.idea/

# Secrets
*.pem
*.key
EOF